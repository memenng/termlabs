{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri.conf.v2.json",
  "productName": "TermLabs",
  "version": "0.2.3",
  "identifier": "com.termlabs.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TermLabs",
        "width": 1024,
        "height": 768,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxQTYzNEU5NkEyQ0FBQzIKUldUQ3FpeHE2VFNtMGF2Skw3a2NhbmgrMURHZEIrTlNOTE5PbHZLTngrVldxbzhMenlpcldkMmoK",
      "endpoints": [
        "https://github.com/memenng/termlabs/releases/latest/download/latest.json"
      ]
    }
  }
}
